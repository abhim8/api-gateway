{
  "timestamp": {
    "$resolver": "timestamp",
    "pattern": {
      "format": "yyyy-MM-dd'T'HH:mm:ss.SSSXXX",
      "timeZone": "UTC"
    }
  },
  "level": {
    "$resolver": "level",
    "field": "name"
  },
  "logger": {
    "$resolver": "logger",
    "field": "name"
  },
  "message": {
    "$resolver": "message"
  },
  "thread": {
    "$resolver": "thread",
    "field": "name"
  },
  "method": {
    "$resolver": "source",
    "field": "methodName"
  },
  "line": {
    "$resolver": "source",
    "field": "lineNumber"
  },
  "correlationId": {
    "$resolver": "mdc",
    "key": "correlationId"
  },
  "traceId": {
    "$resolver": "mdc",
    "key": "traceId"
  },
  "spanId": {
    "$resolver": "mdc",
    "key": "spanId"
  },
  "exception": {
    "message": {
      "$resolver": "exception",
      "field": "message"
    },
    "stackTrace": {
      "$resolver": "exception",
      "field": "stackTrace",
      "stackTrace": {
        "commonElementCount": 0
      }
    }
  }
}
